# Copy this to .env and fill in real values

# ── Anthropic (Phase 1) / Groq (Phase 2) ──────────────────────────
# Phase 1: Anthropic key (swap to GROQ_API_KEY in Phase 2)
ANTHROPIC_API_KEY=your_key_here
# GROQ_API_KEY=your_groq_key_here

# ── Supabase ──────────────────────────────────────────────────────
# Get from: Supabase project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── CORS ──────────────────────────────────────────────────────────
# Comma-separated allowed origins. Localhost + Vercel frontend.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://the-wall-fawn.vercel.app
