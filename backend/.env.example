# Copy this to .env and fill in real values

# Your Anthropic API key — get it at https://console.anthropic.com/
# Leave as placeholder to use the local rule-based fallback roast engine
ANTHROPIC_API_KEY=your_key_here

# Comma-separated list of allowed origins for CORS.
# For local dev the defaults work. For EC2 production, add your EC2 public IP or domain.
# Example: ALLOWED_ORIGINS=http://localhost:3000,http://13.234.56.78,https://thewall.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001
